---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

import MainLayout from '../../layouts/MainLayout.astro';
import BlogPost from '../../components/BlogPost.astro';
import { SITE_CONFIG } from '../../config/site-config';

export const getStaticPaths = (async () => {
  const [authors, blogPosts] = await Promise.all([
    getCollection('author'),
    getCollection('blog'),
  ]);

  return authors.map((author) => ({
    params: { author: author.id },
    props: {
      author,
      blogPosts: blogPosts.filter((post) => post.data.author.id === author.id),
    },
  }));
}) satisfies GetStaticPaths;

const { author, blogPosts } = Astro.props;
---

<MainLayout title={author.data.name}>
  <section class="bg-gray-900">
    <div class="container px-6 py-10 mx-auto">
      <h1 class="text-3xl font-semibold lg:text-4xl text-white">
        {SITE_CONFIG.title}
      </h1>

      <a href="/">Regresar</a>
      <div class="text-md text-gray-400 mb-0 flex flex-row mt-2">
        <Image
          class="rounded-full"
          src={author.data.avatar}
          alt={author.data.name}
          width={50}
          height={50}
        />

        <div class="flex flex-col ml-5">
          <a>{author.data.name}</a>
          <span>Listado de todos mis posts</span>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-8 mt-8 md:mt-16 md:grid-cols-2">
        {blogPosts.map((post) => <BlogPost post={post} />)}
      </div>
    </div>
  </section>
</MainLayout>

<style is:global>
  @reference '../../styles/global.css';

  a {
    @apply text-blue-500 hover:underline;
  }
</style>
