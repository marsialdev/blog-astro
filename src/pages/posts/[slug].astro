---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BlogLayout from '../../layouts/BlogLayout.astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: {
      post,
    },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const frontmatter = post.data;

const { Content, headings } = await render(post);
---

<BlogLayout title={frontmatter.title}>
  <h1>{frontmatter.title}</h1>
  <h4 class="text-sm text-gray-400 mb-0">{frontmatter.author}</h4>

  <Image
    class="object-cover w-full h-[250px] my-5 rounded-md"
    src={frontmatter.image}
    alt={frontmatter.title}
    width={600}
    height={220}
    quality="low"
    loading="lazy"
    transition:name={`${post.id}-image`}
  />

  <!-- Table of Contents -->
  <ol>
    {
      headings.map((heading, index) => (
        <li class="text-sm text-gray-300">
          <a href={`#${heading.slug}`} class="hover:underline">
            {index + 1} - {heading.text}
          </a>
        </li>
      ))
    }
  </ol>

  <!-- Content -->
  <Content />

  <div class="my-20">
    <a href="#btn-back">Ir Arriba</a>
  </div>
</BlogLayout>
<style>
  @reference '../../styles/blog.css';
  h1 {
    @apply text-xs text-gray-500 mb-0;
  }
</style>
