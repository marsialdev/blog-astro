---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { Formatter } from '@utils/formatter';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: {
      post,
    },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const frontmatter = post.data;

const author = (await getEntry('author', frontmatter.author.id))?.data;

if (!author) {
  throw new Error(`Author with id ${frontmatter.author.id} not found`);
}

const { Content, headings } = await render(post);
---

<BlogLayout title={frontmatter.title}>
  <h1>{frontmatter.title}</h1>
  <div class="text-base text-gray-400 mb-0 flex flex-row mt-2">
    <Image
      class="my-5 rounded-full"
      src={author.avatar}
      alt={`${author.name}-imagen`}
      width={50}
      height={50}
      quality="low"
      loading="lazy"
    />
    <div class="flex flex-col justify-center ml-5">
      <a href={`/blog/${frontmatter.author.id}`}>{author.name}</a>
      <span class="text-xs text-gray-200 mb-0"
        >{Formatter.formatDate(frontmatter.date)}</span
      >
    </div>
  </div>

  <Image
    class="object-cover w-full h-[250px] my-5 rounded-md"
    src={frontmatter.image}
    alt={frontmatter.title}
    width={600}
    height={220}
    quality="low"
    loading="lazy"
    transition:name={`${post.id}-image`}
  />

  <!-- Table of Contents -->
  <ol>
    {
      headings.map((heading, index) => (
        <li class="text-sm text-gray-300">
          <a href={`#${heading.slug}`} class="hover:underline">
            {index + 1} - {heading.text}
          </a>
        </li>
      ))
    }
  </ol>

  <!-- Content -->
  <Content />

  <div class="my-20">
    <a href="#btn-back">Ir Arriba</a>
  </div>
</BlogLayout>
<style>
  @reference '../../styles/blog.css';
  h1 {
    @apply text-xs text-gray-500 mb-0;
  }
</style>
